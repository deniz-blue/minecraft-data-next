{
	"name": "minecraft-data-next",
	"version": "0.1.0",
	"description": "Tree-shakeable, ESM-first Minecraft data library",
	"packageManager": "pnpm@10.8.1",
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./java": {
			"types": "./dist/java/index.d.ts",
			"import": "./dist/java/index.js"
		},
		"./java/*": {
			"types": "./dist/java/*/index.d.ts",
			"import": "./dist/java/*/index.js"
		},
		"./java/*/*": {
			"types": "./dist/java/*/*.d.ts",
			"import": "./dist/java/*/*.js"
		}
	},
	"files": [
		"dist",
		"LICENSE",
		"README.md"
	],
	"scripts": {
		"clean": "rm -rf dist src/generated src/java src/protocol src/data",
		"sync:upstream": "tsx scripts/sync-upstream.ts",
		"build": "pnpm run clean && pnpm run generate && pnpm run build:src",
		"build:src": "oxc transform src --out-dir dist && tsc -p tsconfig.lib.json --emitDeclarationOnly",
		"generate": "pnpm run ingest:data && pnpm run generate:protocol",
		"ingest:data": "tsx scripts/ingest-data.ts",
		"generate:protocol": "tsx scripts/generate-protocol-types.ts",
		"typecheck": "echo 'type checking skipped for generated codebase'"
	},
	"keywords": [
		"minecraft",
		"minecraft-data",
		"esm",
		"tree-shaking",
		"protodef"
	],
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^22.15.3",
		"code-block-writer": "^13.0.3",
		"oxc": "latest",
		"protodef-next": "^0.2.1",
		"tsx": "^4.19.2",
		"typescript": "^6.0.2"
	}
}